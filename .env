# Delta-V — local development environment
# Copy this file to .env.local for machine-specific overrides (never commit .env.local).

# The public URL of the deployed site.
# Used for any absolute-URL generation (e.g. og:url meta tags).
VITE_SITE_URL=https://deltav.robertvelardejr.com

# Display title rendered in <title> and og:title
VITE_APP_TITLE=Delta-V
